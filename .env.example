# --- Paths ---
DOWNLOAD_DIR=/opt/qlvb_ai/data/downloads
STORE_DIR=/opt/qlvb_ai/data/store

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=changeme_qdrant_key
QDRANT_COLLECTION=qlvb_docs

# --- Postgres ---
PG_DSN=host=localhost port=5432 dbname=qlvb user=qlvb password=changeme_pg

# --- Embedding ---
EMBEDDING_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
EMBEDDING_DEVICE=cpu

# --- LLM (OpenRouter mặc định) ---
LLM_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-...
LLM_CHEAP=google/gemini-2.5-flash-lite
LLM_MAIN=qwen/qwen-2.5-72b-instruct
LLM_SMART=google/gemini-2.5-pro
